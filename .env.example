# ============================================
# Variables de Base de Datos (PostgreSQL)
# ============================================
DB_USER=lite_user
DB_PASSWORD=lite_password
DB_NAME=lite_db
DB_HOST=IP_ADDRESS

# ============================================
# Llave de Django
# ============================================
DJANGO_SECRET_KEY=tu_llave_django

# ============================================
# Google Gemini — IA Generativa
