# ============================================
# Variables de Base de Datos (PostgreSQL)
# ============================================
DB_USER=lite_user
DB_PASSWORD=lite_password
DB_NAME=lite_db

# ============================================
# Google Gemini — IA Generativa
# ============================================
# Obtén tu API Key en: https://aistudio.google.com/apikey
GEMINI_API_KEY=tu_api_key_aqui

# ============================================
# SMTP — Envío de correos (Mailtrap para testing)
# ============================================
# Regístrate en: https://mailtrap.io
SMTP_SERVER=sandbox.smtp.mailtrap.io
SMTP_USER=tu_usuario_mailtrap
SMTP_PASSWORD=tu_password_mailtrap
SMTP_PORT=2525
